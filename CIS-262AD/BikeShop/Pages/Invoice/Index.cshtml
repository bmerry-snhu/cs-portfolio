@page
@model BikeShop.Pages.Invoice.IndexModel
@{
}
<table cellpadding="5"->
    <tr>
        <th>
            Invoice Id
        </th>
        <th>
            Customer Id
        </th>
        <th>
            Amount
        </th>
        <th>
            Invoice Date
        </th>
        <th>
            Edit
        </th>
        <th>
            Delete
        </th>
    </tr>
    @foreach (BikeShop.DAL.Invoice invoice in Model.Invoices)
    {
        <tr>
            <td>
                @invoice.InvoiceId
            </td>
            <td>
                @invoice.CustomerId
            </td>
            <td>
                @invoice.Amount.ToString("C")
            </td>
            <td>
                @invoice.InvoiceDate.ToShortDateString()
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@invoice.InvoiceId">Edit</a>
            </td>
            <td>
                <a asp-page="./Delete" asp-route-id="@invoice.InvoiceId">Delete</a>
            </td>
        </tr>
    }
</table>
<div>
    <a asp-page="./Edit">Add a New Invoice</a>
</div>