@page
@model BikeShop.Pages.Customer.IndexModel
@{
}
<table cellpadding="5"->
    <tr>
        <th>
            Customer Id
        </th>
        <th>
            First Name
        </th>
        <th>
            Last Name
        </th>
        <th>
            View Invoices
        </th>
        <th>
            Edit
        </th>
        <th>
            Delete
        </th>
    </tr>
    @foreach (BikeShop.DAL.Customer customer in Model.Customers)
    {
        <tr>
            <td>
                @customer.CustomerId
            </td>
            <td>
                @customer.FirstName
            </td>
            <td>
                @customer.LastName
            </td>
            <td>
                <a asp-page="/Invoice" asp-route-id="@customer.CustomerId">View Invoices</a>
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@customer.CustomerId">Edit</a>
            </td>
            <td>
                <a asp-page="./Delete" asp-route-id="@customer.CustomerId">Delete</a>
            </td>
        </tr>
    }
</table>
<div>
    <a asp-page="./Edit">Add a New Customer</a>
</div>